<?xml version="1.0" encoding="utf-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.1">
    <persistence-unit name="Stocky" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.spachecor.model.entity.inventario.Subcategoria</class>
        <class>com.spachecor.model.entity.inventario.Categoria</class>
        <class>com.spachecor.model.entity.inventario.Inventario</class>
        <class>com.spachecor.model.entity.inventario.Lote</class>
        <class>com.spachecor.model.entity.inventario.Transaccion</class>
        <class>com.spachecor.model.entity.inventario.Ubicacion</class>
        <class>com.spachecor.model.entity.inventario.UnidadMedida</class>
        <class>com.spachecor.model.entity.personas.Proveedor</class>
        <class>com.spachecor.model.entity.inventario.Producto</class>
        <class>com.spachecor.model.entity.usuarios.Usuario</class>
        <class>com.spachecor.model.entity.usuarios.Permiso</class>
        <class>com.spachecor.model.entity.usuarios.Rol</class>
        <class>com.spachecor.model.entity.compra.DetalleOrdenCompra</class>
        <class>com.spachecor.model.entity.compra.OrdenCompra</class>
        <class>com.spachecor.model.entity.compra.EntradaMercancia</class>
        <class>com.spachecor.model.entity.compra.DetalleEntradaMercancia</class>
        <class>com.spachecor.model.entity.personas.Cliente</class>
        <class>com.spachecor.model.entity.venta.Venta</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/stocky?serverTimezone=Europe/Madrid"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>